# --- Ollama-first defaults (no key, no money) ---
# These are the script defaults; you only need a .env to override them.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
MODEL=qwen3:1.7b

# --- Frontier / hosted block (uncomment to use a bigger model) ---
# Small local models drive the loop unevenly. A bigger model behaves better.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# MODEL=gpt-4.1-mini

# --- MareNostrum / self-hosted OpenAI-compatible endpoint ---
# OPENAI_BASE_URL=https://your-endpoint/v1
# OPENAI_API_KEY=your-token
# MODEL=your-model-name
