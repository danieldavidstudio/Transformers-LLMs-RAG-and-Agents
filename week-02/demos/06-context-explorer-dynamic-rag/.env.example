# Copy this file to .env and fill in your values.

# CHAT model + EMBEDDINGS model. Default = local Ollama, no key, no cost:
#   ollama serve && ollama pull qwen3:1.7b && ollama pull nomic-embed-text
OPENAI_API_KEY=ollama
MODEL=qwen3:1.7b
EMBED_MODEL=nomic-embed-text
OPENAI_ENDPOINT=http://localhost:11434/v1

# Point PERSIST_PATH at the store you ingested with simple-dynamic-rag/ingest.py,
# or just /seed in-chat for a built-in handbook.
# COLLECTION=handbook
# PERSIST_PATH=./collections-store
# TOP_K=4
# THRESHOLD=0.4
