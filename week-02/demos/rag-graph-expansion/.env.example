# Copy to .env and edit. All four have working defaults for a local Ollama, so
# you can run with no .env at all if Ollama serves the two models below.

# OpenAI-compatible endpoint. Default = local Ollama.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# Chat model that writes the final answer (any small local model is fine).
MODEL=qwen3:1.7b

# Embedding model for the vector retriever. Pull it once: `ollama pull nomic-embed-text`
EMBED_MODEL=nomic-embed-text
